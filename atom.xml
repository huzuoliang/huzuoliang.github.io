      &lt;p&gt;зїЩеЃЪ&lt;script type=&quot;math/tex&quot;&gt;m&lt;/script&gt;дЄ™жХ∞жНЃзВєзЪДжХ∞жНЃйЫЖ&lt;script type=&quot;math/tex&quot;&gt;T=\left\{ \left( \mathbf { x } _ { 1 } , y _ { 1 } \right) , \left( \mathbf { x } _ { 2 } , y _ { 2 } \right) , \ldots , \left( \mathbf { x } _ { m } , y_{ m } \right) \right\}&lt;/script&gt;пЉМеЕґдЄ≠&lt;script type=&quot;math/tex&quot;&gt;\mathbf { x } _ { i } \in \mathcal { R } ^ { n }&lt;/script&gt;пЉМ&lt;script type=&quot;math/tex&quot;&gt;y _ { i } \in \{ \pm 1 \}&lt;/script&gt;пЉМдЄАдЄ™зЇњжАІеИЖз±їеЩ®зЪДе≠¶дє†зЫЃж†ЗжШѓи¶БеЬ®&lt;script type=&quot;math/tex&quot;&gt;n&lt;/script&gt;зїізЪДжХ∞жНЃз©ЇйЧідЄ≠жЙЊеИ∞дЄАдЄ™иґЕеє≥йЭҐе∞ЖжХ∞жНЃйЫЖ&lt;script type=&quot;math/tex&quot;&gt;D&lt;/script&gt;еИЖеЉАпЉМиґЕеє≥йЭҐзЪДжЦєз®ЛеПѓдї•и°®иЊЊдЄЇпЉЪ&lt;/p&gt;
